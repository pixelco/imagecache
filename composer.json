{
    "name": "pixelco/imagecache",
    "description": "Caching extension for the Pixelco Image Class",
    "homepage": "https://pixelcostudios.com",
    "keywords": [
        "image",
        "gd",
        "imagick",
        "laravel",
        "cache"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Gleen Ferdinand",
            "email": "info@pixelcostudios.com",
            "homepage": "http://pixelcostudios.com/"
        }
    ],
    "require": {
        "php": "~7.2|~8",
        "pixelco/image": "~2.2",
        "illuminate/cache": "^5.5|~6|~7|~8|~9|~10",
        "illuminate/filesystem": "^5.5|~6|~7|~8|~9|~10",
        "nesbot/carbon": "^2.39",
        "opis/closure": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Pixelco\\Image\\": "src/Pixelco/Image"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixelco\\Image\\Test\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
